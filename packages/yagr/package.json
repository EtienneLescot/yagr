{
  "name": "yagr",
  "version": "0.1.0",
  "description": "Yagr agent layer for turning intent into automation",
  "type": "module",
  "bin": {
    "yagr": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b && node scripts/build-webui.mjs",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "npm run build && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@clack/prompts": "^1.1.0",
    "@n8n-as-code/skills": "1.1.2",
    "@n8n-as-code/transformer": "1.0.1",
    "@types/qrcode-terminal": "^0.12.2",
    "ai": "^4.3.19",
    "conf": "^13.0.1",
    "dotenv": "^17.2.3",
    "fullscreen-ink": "^0.1.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "n8nac": "1.1.2",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "telegraf": "^4.16.3",
    "zustand": "^5.0.8",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/react-dom": "^19.2.3",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.25.3",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EtienneLescot/yagr"
  },
  "publishConfig": {
    "access": "public"
  }
}
